# =============================================================
# TBDS Control — EvoBox 部署环境变量
# 复制此文件为 .env 并填入真实值：
#   cp deploy/.env.example deploy/.env
#
# ⚠️ .env 包含真实密码，已加入 .gitignore，勿提交
# =============================================================

# ─── 节点 SSH 连接 ──────────────────────────────────
EVOBOX_NODE1="root@182.43.16.222"    # Agent only
EVOBOX_NODE2="root@182.43.22.165"    # Server + Agent + Redis
EVOBOX_NODE3="root@182.43.29.236"    # MySQL + Agent

# ─── MySQL ──────────────────────────────────────────
MYSQL_USER="tm"
MYSQL_PASSWORD="<YOUR_MYSQL_PASSWORD>"

# ─── Redis ──────────────────────────────────────────
REDIS_PASSWORD="<YOUR_REDIS_PASSWORD>"
